# ===== Conclave 环境变量示例 =====
# 复制为 .env 并填入真实值。无任何 key 时系统自动走 stub 模式（可端到端跑通）。

# ----- LLM -----
# 留空 = 使用 StubLLM（返回符合 schema 的假数据，用于验证流程）
CONCLAVE_LLM_API_KEY=
CONCLAVE_LLM_BASE_URL=https://api.siliconflow.cn/v1
CONCLAVE_LLM_MODEL=Qwen/Qwen3.5-4B

# LLM 确定性参数（可选，默认值保持向后兼容）
# CONCLAVE_LLM_SEED=42
# CONCLAVE_LLM_TOP_P=1.0
# CONCLAVE_LLM_NO_THINK=1
# CONCLAVE_LLM_MAX_PROMPT_TOKENS=32000
# CONCLAVE_LLM_MAX_ATTEMPTS=3
# CONCLAVE_LLM_TIMEOUT=120.0
# CONCLAVE_PRODUCE_TIMEOUT=1200.0
# CONCLAVE_LLM_CIRCUIT_THRESHOLD=5
# CONCLAVE_LLM_CIRCUIT_RECOVERY=60.0
# CONCLAVE_LLM_STAGE_TEMPERATURES={"clarify":0.0,"intra_team":0.3,"cross_team":0.0,"evidence_check":0.0,"arbitrate":0.0,"produce":0.1}

# ----- Embedding -----
# 留空 = 使用 StubEmbedding（确定性 hash 伪向量）
CONCLAVE_EMBED_API_KEY=
CONCLAVE_EMBED_BASE_URL=https://api.siliconflow.cn/v1
CONCLAVE_EMBED_MODEL=BAAI/bge-m3

# ----- Reranker -----
# 留空 = 使用关键词加成重排
CONCLAVE_RERANK_API_KEY=
CONCLAVE_RERANK_BASE_URL=https://api.siliconflow.cn/v1
CONCLAVE_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ----- 数据库（PostgreSQL）-----
DATABASE_URL=postgresql+asyncpg://conclave:conclave_dev@localhost:5432/conclave
# 数据目录路径（用于密钥文件等，非数据库路径）
CONCLAVE_DB_PATH=/app/data/conclave.db

# ----- Redis -----
REDIS_URL=redis://localhost:6379/0

# ----- Qdrant 向量库 -----
# 留空 = 使用内存伪向量
CONCLAVE_QDRANT_URL=
CONCLAVE_QDRANT_COLLECTION=conclave_chunks

# ----- API 认证 -----
# 留空 = 开发模式（自动生成 token 并写入 .dev_token 文件）
CONCLAVE_API_TOKEN=
# Fernet 加密密钥（用于 BYOK API Key 加密存储）
# 留空 = 首次启动自动生成并持久化到数据目录
CONCLAVE_SECRET_KEY=

# ----- PostgreSQL 容器配置（docker-compose 使用）-----
POSTGRES_PASSWORD=conclave_dev

# ----- 记忆系统 -----
# 设置为 1 时禁用三层记忆提取（测试用）；留空或未设置时启用
# CONCLAVE_MEMORY_DISABLED=1

# ----- 超时配置 -----
CONCLAVE_LLM_TIMEOUT=120.0
CONCLAVE_PRODUCE_TIMEOUT=1200.0

# ----- 沙箱配置 -----
CONCLAVE_SANDBOX_MODE=auto
# 设为 true 禁用 Docker 沙箱（无 Docker 环境时使用）
CONCLAVE_DOCKER_DISABLED=false

# ----- 工作区 -----
CONCLAVE_WORKSPACE_DIR=/workspace

# ----- 服务 -----
HOST=127.0.0.1
PORT=8000
