# ===== Conclave 环境变量示例 =====
# 复制为 .env 并填入真实值。无任何 key 时系统自动走 stub 模式（可端到端跑通）。

# ----- LLM -----
# 留空 = 使用 StubLLM（返回符合 schema 的假数据，用于验证流程）
# 填入则走 OpenAI 兼容接口
CONCLAVE_LLM_API_KEY=
CONCLAVE_LLM_BASE_URL=https://api.openai.com/v1
CONCLAVE_LLM_MODEL=gpt-4o-mini

# ----- 向量库 -----
# 留空 = 使用内存向量存储（StubEmbedding 伪向量）
# 填入则走 Qdrant（迭代一未实现，预留）
CONCLAVE_VECTOR_STORE_URL=
CONCLAVE_VECTOR_STORE_COLLECTION=conclave

# ----- 数据库 -----
# SQLite 路径，留空则用 ./conclave.db
CONCLAVE_DB_PATH=

# ----- 服务 -----
HOST=127.0.0.1
PORT=8000
